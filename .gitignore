# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.hf-cache/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# runtime state files
tts-timeout-state.json
src/data/tts-word-replacements.json
public/sounds/*
public/photos/character.png
omnivoice-env/*
parakeet-env/*
omnivoice-local/references/*

# keep one OmniVoice patched file tracked
!omnivoice-env/lib/
omnivoice-env/lib/*
!omnivoice-env/lib/python3.10/
omnivoice-env/lib/python3.10/*
!omnivoice-env/lib/python3.10/site-packages/
omnivoice-env/lib/python3.10/site-packages/*
!omnivoice-env/lib/python3.10/site-packages/omnivoice/
omnivoice-env/lib/python3.10/site-packages/omnivoice/*
!omnivoice-env/lib/python3.10/site-packages/omnivoice/utils/
omnivoice-env/lib/python3.10/site-packages/omnivoice/utils/*
!omnivoice-env/lib/python3.10/site-packages/omnivoice/utils/audio.py
